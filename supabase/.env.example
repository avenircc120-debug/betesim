# ============================================================
#  SECRETS SUPABASE — FONCTIONS EDGE
#  À configurer dans : Supabase Dashboard → Settings → Edge Functions → Secrets
# ============================================================

# ── FedaPay Sandbox (mode test) ──
FEDAPAY_PUBLIC_KEY=pk_sandbox_VOTRE_CLE_PUBLIQUE_SANDBOX
FEDAPAY_SECRET_KEY=sk_sandbox_VOTRE_CLE_SECRETE_SANDBOX

# ── FedaPay Live (mode production) ──
# FEDAPAY_PUBLIC_KEY=pk_live_VOTRE_CLE_PUBLIQUE_LIVE
# FEDAPAY_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE_LIVE

# ── Webhook FedaPay ──
# Disponible dans FedaPay Dashboard → Webhooks → Votre webhook → Secret
FEDAPAY_WEBHOOK_SECRET=VOTRE_SECRET_WEBHOOK_FEDAPAY
